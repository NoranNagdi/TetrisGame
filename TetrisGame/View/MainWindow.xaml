<Window x:Class="TetrisGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TetrisGame"
        xmlns:vm="clr-namespace:TetrisGame.ViewModel"
        mc:Ignorable="d"
        Title="Tetris Game" Height="700" Width="1000">


    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    
    <Grid  Background="SteelBlue">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>


        <!-- Main Logo -->
        <TextBlock Grid.ColumnSpan="2" Text="Tetris" FontSize="60" FontFamily="Comic Sans MS" HorizontalAlignment="Center">
            <TextBlock.Foreground>
                <LinearGradientBrush>
                    <GradientStop Color="Maroon" Offset="0.2"/>
                    <GradientStop Color="Tomato" Offset="0.4"/>
                    <GradientStop Color="LightCyan" Offset="0.6"/>
                    <GradientStop Color="LightGreen" Offset="0.8"/>
                    <GradientStop Color="Teal" Offset="1"/>
                </LinearGradientBrush>
            </TextBlock.Foreground>
        </TextBlock>


        <!-- Game Grid -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="3" 
                Background="Black" Margin="20">

            <ItemsControl ItemsSource="{Binding TetrominoBlocks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid ShowGridLines="True">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Rectangle Fill="{Binding Color}" Stroke="White" Width="30" Height="30"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>


        <!-- Side Grid -->
        <Grid Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border BorderBrush="PowderBlue" BorderThickness="3" Margin="0 0 20 0">
                <TextBlock Grid.Row="0" Foreground="Teal" Background="AliceBlue" 
                           FontSize="40" TextAlignment="Center" FontFamily="Comic Sans MS" FontWeight="Bold">
                <Run Text="Score"/>
                <LineBreak/>
                <Run Text="{Binding Score}"/>
                </TextBlock>
            </Border>


            <Button Grid.Row="2" Margin="0 150 20 0" Content="Pause Game" Height="70" 
                    FontSize="25" FontFamily="Comic Sans MS" Click="Pause_Button"
                    Background="AliceBlue" BorderBrush="PowderBlue" BorderThickness="3">
            </Button>

            
            
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="2" CornerRadius="15" BorderBrush="White" BorderThickness="2" Background="Black" Padding="20" Visibility="{Binding IsGameOver, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                <TextBlock Text="Game Over! Your Final Score is" FontSize="36" FontWeight="Bold" Foreground="DarkRed" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Score}" FontSize="40" FontWeight="Bold" Foreground="DarkRed" Margin="0,20,0,20" HorizontalAlignment="Center"/>

                <Button Content="Restart" Height="70" FontSize="25" FontFamily="Comic Sans MS" Click="Restart_Button"
                        Background="AliceBlue" BorderBrush="PowderBlue" BorderThickness="3">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>


   
